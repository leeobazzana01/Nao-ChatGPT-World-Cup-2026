#CHANGE FOR THE OPENAI API KEY
OPENAI_API_KEY=sk-proj-your-openai-api-key-here

OPENAI_CHAT_MODEL=gpt-4o #chat/vision model

OPENAI_WHISPER_MODEL=whisper-1 #audio transcription of openai

HOST=0.0.0.0 #server
PORT=8080

#TOKEN that the robot sends on header for authentication
AUTH_TOKEN=change-this-auth-token

#session time in seconds until a session expires due to inactivity (3600 = 1 hour)
SESSION_TTL_SECONDS=3600

#maximum messages for session
SESSION_MAX_HISTORY=30

#RAG (Retrieval Augmented Generation) file path 
KNOWLEDGE_DIR=./data/knowledge

#max numbers of chunks included
RAG_TOP_K=5

#max size of each knowledge chunk in characteres
RAG_CHUNK_SIZE=800

#rate limiting, max requests for ip by minute
RATE_LIMIT_PER_IP=30

#max requests per minute per chat_id
RATE_LIMIT_PER_SESSION=20

#logging
LOG_LEVEL=INFO

#log directory
LOG_DIR=./logs

#timeouts
OPENAI_TIMEOUT=60
REQUEST_MAX_SIZE_MB=25

#default persona
DEFAULT_PERSONA=torcedor-brasileiro

#default langauge for english
DEFAULT_LANGUAGE=pt-br

#personas directory (one .txt per persona, slug = filename)
PERSONAS_DIR=./data/personas

#--- Copa do Mundo 2026 feature ---
#enable the World Cup scheduler + /copa/live endpoint
COPA_ENABLED=true

#optional real-time source for GET /copa/live (empty = offline, dict only)
#expected to accept ?home=&away= and return JSON {status, home_score, away_score}
COPA_LIVE_SOURCE_URL=

#how often (seconds) the scheduler checks for matches that just finished
COPA_SCHEDULER_TICK_SECONDS=60
